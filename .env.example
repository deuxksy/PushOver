# Cloudflare API Token
# 권한: Account, Workers Scripts, Workers D1, Workers KV
# 생성: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_api_token_here

# Cloudflare Account ID
# 확인: https://dash.cloudflare.com → Right sidebar
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Worker Configuration
WORKER_NAME=pushover-worker
WORKER_API_URL=https://api.pushover.net

# Webhook Secret (서명 생성 권장)
# 생성: openssl rand -base64 32
WEBHOOK_SECRET=your_webhook_secret_here

# PushOver API Credentials
# 확인: https://pushover.net
PUSHOVER_USER_KEY=your_pushover_user_key_here
PUSHOVER_API_TOKEN=your_pushover_api_token_here

# Dashboard Configuration
NEXT_PUBLIC_API_URL=http://localhost:8787
NEXT_PUBLIC_WORKER_URL=https://pushover-worker.your-subdomain.workers.dev

# D1 Database (wrangler에서 자동 생성됨)
D1_DATABASE_ID=auto_generated_by_wrangler

# Zone ID (선택 - 커스텀 도메인 사용 시)
CLOUDFLARE_ZONE_ID=your_zone_id_here

# ===================================
# Test Environment (Playwright E2E Tests)
# ===================================
# Worker URL for testing
CF_WORKER_URL=https://pushover-worker.your-subdomain.workers.dev

# Worker 인증 토큰 (API 호출용)
# 생성: Worker API에서 등록 또는 wrangler 명령어로 생성
CF_WORKER_TOKEN=your-worker-api-token-here
