{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "loc": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:loc": "npx playwright test --project=loc",
    "test:loc:headed": "npx playwright test --project=loc --headed",
    "test:dev": "npx playwright test --project=dev",
    "test:dev:headed": "npx playwright test --project=dev --headed",
    "test:all": "npx playwright test",
    "pages:build": "npx @cloudflare/next-on-pages",
    "deploy": "pnpm run pages:build && wrangler pages deploy .vercel/output/static --project-name=pushover-dashboard --commit-dirty=true --commit-message=\"deploy dashboard\""
  },
  "dependencies": {
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
